{
  "name": "beatz-fit",
  "version": "1.0.0",
  "description": "BeatZ Fit — Immersive Music Fitness Desktop App",
  "author": "BeatZ Fit",
  "license": "MIT",
  "main": "dist-electron/main/index.js",
  "keywords": [
    "electron",
    "vue3",
    "threejs",
    "music-player",
    "fitness",
    "3d-visualization",
    "audio-visualizer",
    "liquid-glass"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:vite": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-updater": "^6.8.9",
    "music-metadata": "^10.5.0",
    "NeteaseCloudMusicApi": "^4.32.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/howler": "^2.2.12",
    "@types/sharp": "^0.32.0",
    "@types/sql.js": "^1.4.9",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.11",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "gsap": "^3.12.5",
    "howler": "^2.2.4",
    "jsdom": "^25.0.1",
    "pinia": "^2.3.0",
    "sass": "^1.83.0",
    "three": "^0.170.0",
    "troika-three-text": "^0.52.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vitest": "^3.2.7",
    "vue-tsc": "^2.2.0"
  },
  "build": {
    "appId": "com.beatzfit.app",
    "productName": "BeatZ Fit",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icons/icon.ico"
    },
    "electronLanguages": ["zh-CN", "en-US"],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icons/icon.ico",
      "uninstallerIcon": "resources/icons/icon.ico",
      "installerHeaderIcon": "resources/icons/icon.ico",
      "include": "build/beatzfit-installer.nsh",
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BeatZ Fit"
    },
    "compression": "maximum",
    "afterPack": "./build/afterPack.js",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*",
      "!**/LICENSES.chromium.html",
      "!**/node_modules/NeteaseCloudMusicApi/public/**",
      "!**/node_modules/sql.js/dist/*-debug*"
    ],
    "artifactName": "BeatZ-Fit-Setup-${version}.${ext}",
    "publish": {
      "provider": "github",
      "owner": "ZZ-Jie",
      "repo": "BeatZFit"
    }
  }
}
